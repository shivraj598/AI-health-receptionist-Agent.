NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# OPTIONAL: Business ID for the live demo widget on the landing page
# Leave empty to hide the widget entirely. Fill in when you want to enable it.
NEXT_PUBLIC_DEMO_BUSINESS_ID=

OPENAI_REALTIME_MODEL=gpt-realtime

NEXT_PUBLIC_ENABLE_VOICE=true

# Resend — get your key at https://resend.com/api-keys
RESEND_API_KEY=
# Resend's shared sender — works without domain verification for local testing
RESEND_FROM_EMAIL=onboarding@resend.dev
# Redirect ALL outgoing emails to your inbox during local dev
RESEND_DEV_OVERRIDE_TO=


# ── Stripe ────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# ── Website Builder ────────────────────────────────────────────────────────────
# Monthly price in USD for website builder subscription
NEXT_PUBLIC_WEBSITE_BUILDER_PRICE_USD=29

# ── Subscription Plans ─────────────────────────────────────────────────────────
# Plan names
NEXT_PUBLIC_FREE_PLAN_NAME=Free
NEXT_PUBLIC_PRO_PLAN_NAME=Pro
NEXT_PUBLIC_BUSINESS_PLAN_NAME=Business

# Plan prices in USD (Free is always 0)
NEXT_PUBLIC_PRO_PLAN_PRICE_USD=49
NEXT_PUBLIC_BUSINESS_PLAN_PRICE_USD=199

# Agent limits per plan
NEXT_PUBLIC_FREE_AGENT_LIMIT=1
NEXT_PUBLIC_PRO_AGENT_LIMIT=10
# Business plan = unlimited (set to 0 to mean unlimited)
NEXT_PUBLIC_BUSINESS_AGENT_LIMIT=0

# Booking limits per plan
NEXT_PUBLIC_FREE_BOOKING_LIMIT=5
NEXT_PUBLIC_PRO_BOOKING_LIMIT=99
# Business plan = unlimited (set to 0 to mean unlimited)
NEXT_PUBLIC_BUSINESS_BOOKING_LIMIT=0
